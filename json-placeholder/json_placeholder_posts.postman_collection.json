						"exec": [
							"const schema = {",
							" //   \"$schema\": \"https://gregsdennis.github.io/json-everything/meta/unique-keys\",",
							"    \"type\": \"array\",",
							"    \"properties\": {",
							"                \"id\": { \"type\": \"number\"},",
							"                \"userId\": { \"type\": \"number\"},",
							"                \"title\": { \"type\": \"string\"},",
							"                \"body\": { \"type\": \"string\"}",
							"            },",
							"    \"required\": [\"userId\", \"title\",\"id\"],",
							"//    \"uniqueKeys\": [\"/id\"]",
							"        ",
							"};",
							"const response = pm.response.json();",
							"",
							"console.log(response)",
							"",
							"pm.test('API response schema is valid ', () => {",
							"    pm.expect(response).to.have.jsonSchema(schema);",
							"}); ",
							"",
							"pm.test('API response contais correct userId ', () => {",
							"    pm.expect(response[\"userId\"]).to.be.greaterThan(0);",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
